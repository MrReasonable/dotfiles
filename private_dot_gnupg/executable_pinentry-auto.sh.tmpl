#!/bin/sh
# Auto-select pinentry based on PINENTRY_USER_DATA forwarded by gpg-agent.
# .zshrc sets USE_TTY=1 inside SSH sessions and the zsh-gpg-agent plugin sets
# USE_CURSES=1 inside interactive terminal sessions; both route to
# pinentry-curses. Otherwise fall back to the GUI pinentry-mac.
case "$PINENTRY_USER_DATA" in
  *USE_TTY=1*|*USE_CURSES=1*) exec {{ if eq .chezmoi.arch "arm64" }}/opt/homebrew/bin/pinentry-curses{{ else }}/usr/local/bin/pinentry-curses{{ end }} "$@" ;;
  *)                          exec {{ if eq .chezmoi.arch "arm64" }}/opt/homebrew/bin/pinentry-mac{{ else }}/usr/local/bin/pinentry-mac{{ end }} "$@" ;;
esac
